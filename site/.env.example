# Optional JupyterLab link target for notebook buttons in the web app
VITE_JUPYTER_BASE_URL=http://localhost:8888

# Optional Supabase cloud sync (cross-device progress persistence)
# Create a Supabase project, then copy these values from Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional table name override (default: study_progress)
VITE_SUPABASE_PROGRESS_TABLE=study_progress
